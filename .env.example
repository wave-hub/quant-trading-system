# Application Settings
APP_NAME=QuantTradingSystem
APP_VERSION=1.0.0
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/quant_trading
DATABASE_TEST_URL=postgresql://postgres:password@localhost:5432/quant_trading_test

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Data Sources
TUSHARE_TOKEN=your-tushare-token
AKSHARE_ENABLED=True

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# RQAlpha
RQALPHA_BUNDLE_PATH=data/bundles

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Task Settings
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=data/uploads
